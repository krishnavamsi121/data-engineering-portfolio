# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform directory
.terraform/
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Variable files that might contain sensitive data
# Comment this out if you want to commit your tfvars
# terraform.tfvars
# *.auto.tfvars
# *.auto.tfvars.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore Mac files
.DS_Store
